general: {
        http = false # Whether to enable the plain HTTP interface
        port = 10088 # Web server HTTP port
        https = true # Whether to enable HTTPS (default=false)
        secure_port = 10089 # Web server HTTPS port, if enabled
}

certificates: {
        cert_pem = "/usr/local/etc/janus/cert.pem"
        cert_key = "/usr/local/etc/janus/januskey.pem"
        #cert_pwd = "pass" #secretpassphrase
}

cors: {
  #enforce_cors = false
}